generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model configuraciones {
  id                 BigInt         @id @default(autoincrement())
  nombre_empresa     String         @db.VarChar(120)
  prompt_sistema     String
  id_tipo_respuesta  BigInt
  mensaje_bienvenida String?
  mensaje_fallback   String?
  horario_habilitado Boolean        @default(false)
  horario_json       Json?          @db.Json
  creado_en          DateTime       @default(now()) @db.Timestamp(6)
  actualizado_en     DateTime       @default(now()) @db.Timestamp(6)
  tipo_respuesta     tipo_respuesta @relation(fields: [id_tipo_respuesta], references: [id], onUpdate: Restrict, map: "fk_configuracion_tipo_respuesta")
}

model conversaciones {
  id                BigInt     @id @default(autoincrement())
  telefono_usuario  String     @db.VarChar(20)
  iniciado_en       DateTime   @default(now()) @db.Timestamp(6)
  ultimo_mensaje_en DateTime   @default(now()) @db.Timestamp(6)
  esta_activa       Boolean?   @default(true)
  mensajes          mensajes[]
}

model mensajes {
  id              BigInt         @id @default(autoincrement())
  id_conversacion BigInt
  remitente       tipo_remitente
  mensaje         String
  prompt_enviado  String?
  creado_en       DateTime       @default(now()) @db.Timestamp(6)
  conversaciones  conversaciones @relation(fields: [id_conversacion], references: [id], onUpdate: Restrict, map: "fk_mensajes_conversacion")

  @@index([id_conversacion], map: "idx_mensajes_conversacion")
}

model permisos {
  id                                              Int             @id @default(autoincrement())
  usuario_crea_fk                                 Int
  fecha_crea                                      DateTime        @default(now()) @db.Timestamp(6)
  fecha_modifica                                  DateTime        @default(now()) @db.Timestamp(6)
  codigo                                          String          @unique @db.VarChar(100)
  nombre                                          String          @db.VarChar(100)
  descripcion                                     String?
  activo                                          Boolean         @default(true)
  usuario_modifica_fk                             Int
  usuarios_permisos_usuario_crea_fkTousuarios     usuarios        @relation("permisos_usuario_crea_fkTousuarios", fields: [usuario_crea_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_crea")
  usuarios_permisos_usuario_modifica_fkTousuarios usuarios        @relation("permisos_usuario_modifica_fkTousuarios", fields: [usuario_modifica_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usuario_modifica_fk")
  roles_permiso                                   roles_permiso[]
}

model productos {
  id               Int            @id @default(autoincrement())
  id_tipo_producto Int
  nombre           String         @db.VarChar(150)
  descripcion      String?
  precio           Decimal?       @db.Decimal(10, 2)
  stock            Int?           @default(0)
  esta_activo      Boolean?       @default(true)
  creado_en        DateTime       @default(now()) @db.Timestamp(6)
  tipos_producto   tipos_producto @relation(fields: [id_tipo_producto], references: [id], onUpdate: Restrict, map: "fk_productos_tipo")

  @@index([id_tipo_producto], map: "idx_productos_tipo")
}

model roles {
  id                                           Int              @id @default(autoincrement())
  usuario_crea_fk                              Int
  fecha_crea                                   DateTime         @default(now()) @db.Timestamp(6)
  fecha_modifica                               DateTime         @default(now()) @db.Timestamp(6)
  codigo                                       String           @unique @db.VarChar(100)
  nombre                                       String           @db.VarChar(100)
  descripcion                                  String?
  modulo                                       String?          @db.VarChar(100)
  activo                                       Boolean          @default(true)
  usuario_modifica_fk                          Int
  usuarios_roles_usuario_crea_fkTousuarios     usuarios         @relation("roles_usuario_crea_fkTousuarios", fields: [usuario_crea_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_crea")
  usuarios_roles_usuario_modifica_fkTousuarios usuarios         @relation("roles_usuario_modifica_fkTousuarios", fields: [usuario_modifica_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usuario_modifica_fk")
  roles_permiso                                roles_permiso[]
  usuarios_roles                               usuarios_roles[]
}

model roles_permiso {
  id                                                   Int      @id @default(autoincrement())
  usuario_crea_fk                                      Int
  fecha_crea                                           DateTime @default(now()) @db.Timestamp(6)
  fecha_modifica                                       DateTime @default(now()) @db.Timestamp(6)
  rol_fk                                               Int
  permiso_fk                                           Int
  usuario_modifica_fk                                  Int
  usuarios_roles_permiso_usuario_crea_fkTousuarios     usuarios @relation("roles_permiso_usuario_crea_fkTousuarios", fields: [usuario_crea_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_crea")
  permisos                                             permisos @relation(fields: [permiso_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "permiso_fk")
  roles                                                roles    @relation(fields: [rol_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "rol_fk")
  usuarios_roles_permiso_usuario_modifica_fkTousuarios usuarios @relation("roles_permiso_usuario_modifica_fkTousuarios", fields: [usuario_modifica_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usuario_modifica_fk")
}

model tipo_respuesta {
  id              BigInt            @id @default(autoincrement())
  nombre_tipo     String            @db.VarChar(50)
  descripcion     String?           @db.VarChar(255)
  creado_en       DateTime          @default(now()) @db.Timestamp(6)
  actualizado_en  DateTime          @default(now()) @db.Timestamp(6)
  configuraciones configuraciones[]
}

model tipos_producto {
  id        Int         @id @default(autoincrement())
  nombre    String      @db.VarChar(50)
  productos productos[]
}

model usuarios {
  id                                                          Int              @id @default(autoincrement())
  usuario_crea_fk                                             Int
  usuario_modifica_fk                                         Int
  fecha_crea                                                  DateTime         @default(now()) @db.Timestamp(6)
  fecha_modifica                                              DateTime         @default(now()) @db.Timestamp(6)
  usuario                                                     String           @unique @db.VarChar(100)
  primer_nombre                                               String           @db.VarChar(100)
  segundo_nombre                                              String?          @db.VarChar(100)
  primer_apellido                                             String           @db.VarChar(100)
  segundo_apellido                                            String?          @db.VarChar(100)
  numero_identificacion                                       String           @db.VarChar(10)
  email                                                       String           @unique(map: "unique_email") @db.VarChar(200)
  contrasena                                                  String
  activo                                                      Boolean          @default(true)
  permisos_permisos_usuario_crea_fkTousuarios                 permisos[]       @relation("permisos_usuario_crea_fkTousuarios")
  permisos_permisos_usuario_modifica_fkTousuarios             permisos[]       @relation("permisos_usuario_modifica_fkTousuarios")
  roles_roles_usuario_crea_fkTousuarios                       roles[]          @relation("roles_usuario_crea_fkTousuarios")
  roles_roles_usuario_modifica_fkTousuarios                   roles[]          @relation("roles_usuario_modifica_fkTousuarios")
  roles_permiso_roles_permiso_usuario_crea_fkTousuarios       roles_permiso[]  @relation("roles_permiso_usuario_crea_fkTousuarios")
  roles_permiso_roles_permiso_usuario_modifica_fkTousuarios   roles_permiso[]  @relation("roles_permiso_usuario_modifica_fkTousuarios")
  usuarios_usuarios_usuario_crea_fkTousuarios                 usuarios         @relation("usuarios_usuario_crea_fkTousuarios", fields: [usuario_crea_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_crea")
  other_usuarios_usuarios_usuario_crea_fkTousuarios           usuarios[]       @relation("usuarios_usuario_crea_fkTousuarios")
  usuarios_usuarios_usuario_modifica_fkTousuarios             usuarios         @relation("usuarios_usuario_modifica_fkTousuarios", fields: [usuario_modifica_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usuario_modifica_fk")
  other_usuarios_usuarios_usuario_modifica_fkTousuarios       usuarios[]       @relation("usuarios_usuario_modifica_fkTousuarios")
  usuarios_roles_usuarios_roles_usuario_crea_fkTousuarios     usuarios_roles[] @relation("usuarios_roles_usuario_crea_fkTousuarios")
  usuarios_roles_usuarios_roles_usuario_fkTousuarios          usuarios_roles[] @relation("usuarios_roles_usuario_fkTousuarios")
  usuarios_roles_usuarios_roles_usuario_modifica_fkTousuarios usuarios_roles[] @relation("usuarios_roles_usuario_modifica_fkTousuarios")
  usuarios_token_usuarios_token_usuario_crea_fkTousuarios     usuarios_token[] @relation("usuarios_token_usuario_crea_fkTousuarios")
  usuarios_token_usuarios_token_usuario_fkTousuarios          usuarios_token[] @relation("usuarios_token_usuario_fkTousuarios")
  usuarios_token_usuarios_token_usuario_modifica_fkTousuarios usuarios_token[] @relation("usuarios_token_usuario_modifica_fkTousuarios")
}

model usuarios_roles {
  id                                                    Int      @id @default(autoincrement())
  usuario_crea_fk                                       Int
  usuario_modifica_fk                                   Int
  fecha_crea                                            DateTime @default(now()) @db.Timestamp(6)
  fecha_modifica                                        DateTime @default(now()) @db.Timestamp(6)
  usuario_fk                                            Int
  rol_fk                                                Int
  usuarios_usuarios_roles_usuario_crea_fkTousuarios     usuarios @relation("usuarios_roles_usuario_crea_fkTousuarios", fields: [usuario_crea_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_crea")
  roles                                                 roles    @relation(fields: [rol_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "rol_fk")
  usuarios_usuarios_roles_usuario_fkTousuarios          usuarios @relation("usuarios_roles_usuario_fkTousuarios", fields: [usuario_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usuario_fk")
  usuarios_usuarios_roles_usuario_modifica_fkTousuarios usuarios @relation("usuarios_roles_usuario_modifica_fkTousuarios", fields: [usuario_modifica_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usuario_modifica_fk")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model usuarios_token {
  id                                                    Int      @id @default(autoincrement())
  usuario_crea_fk                                       Int
  fecha_crea                                            DateTime @default(now()) @db.Timestamp(6)
  fecha_modifica                                        DateTime @default(now()) @db.Timestamp(6)
  usuario_fk                                            Int
  token                                                 String
  tipo                                                  String   @db.VarChar(30)
  activo                                                Boolean  @default(true)
  ip_origen                                             String   @db.VarChar(30)
  user_agent                                            String   @db.VarChar(80)
  fecha_expiracion                                      DateTime @db.Timestamp(6)
  usuario_modifica_fk                                   Int
  usuarios_usuarios_token_usuario_crea_fkTousuarios     usuarios @relation("usuarios_token_usuario_crea_fkTousuarios", fields: [usuario_crea_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_crea")
  usuarios_usuarios_token_usuario_fkTousuarios          usuarios @relation("usuarios_token_usuario_fkTousuarios", fields: [usuario_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usuario_fk")
  usuarios_usuarios_token_usuario_modifica_fkTousuarios usuarios @relation("usuarios_token_usuario_modifica_fkTousuarios", fields: [usuario_modifica_fk], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "usuario_modifica_fk")
}

enum tipo_remitente {
  usuario
  asistente
}
